# Database configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/ymovies

# TMDB API Key (The Movie Database)
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Recommendation service URL
RECOMMENDATION_SERVICE_URL=http://localhost:5100

# Session secret (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# Replit-specific variables (only needed for Replit deployment)
# REPL_ID=
# REPLIT_DOMAINS=
# ISSUER_URL=https://replit.com/oidc
